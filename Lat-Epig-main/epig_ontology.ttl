epig:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliated with"@en ;
    rdfs:comment "Affiliation relationship between a person and a community."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Community .

epig:ageAtDeath a owl:DatatypeProperty ;
    rdfs:label "age at death"@en ;
    rdfs:comment "The age of the person at time of death, as recorded in the inscription."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:integer .

epig:ageAtDeathEvidence a owl:DatatypeProperty ;
    rdfs:label "age at death evidence"@en ;
    rdfs:comment "Textual evidence for the recorded age at death."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:benefactionText a owl:DatatypeProperty ;
    rdfs:label "benefaction text"@en ;
    rdfs:comment "The relevant passage from the inscription describing the benefaction."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:benefactionType a owl:DatatypeProperty ;
    rdfs:label "benefaction type"@en ;
    rdfs:comment "The category of benefaction (construction, donation, games, etc.)."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:cognomen a owl:ObjectProperty ;
    rdfs:label "cognomen"@en ;
    rdfs:comment "The Roman cognomen of the person."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Cognomen .

epig:communityType a owl:ObjectProperty ;
    rdfs:label "community type"@en ;
    rdfs:comment "The type or category of the community."@en ;
    rdfs:domain epig:Community ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:CommunityType .

epig:cost a owl:DatatypeProperty ;
    rdfs:label "cost"@en ;
    rdfs:comment "The cost of the benefaction as stated in the inscription."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:costConversionReasoning a owl:DatatypeProperty ;
    rdfs:label "cost conversion reasoning"@en ;
    rdfs:comment "Explanation of how the cost was converted to the numeric value."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:costNumeric a owl:DatatypeProperty ;
    rdfs:label "cost numeric"@en ;
    rdfs:comment "The cost converted to a numeric value in sesterces."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:decimal .

epig:costUnit a owl:DatatypeProperty ;
    rdfs:label "cost unit"@en ;
    rdfs:comment "The monetary unit used for the cost (sestertius, denarius, etc.)."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:datingFrom a owl:DatatypeProperty ;
    rdfs:label "dating from"@en ;
    rdfs:comment "Earliest possible date of the inscription (year CE, negative = BCE)."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:integer .

epig:datingTo a owl:DatatypeProperty ;
    rdfs:label "dating to"@en ;
    rdfs:comment "Latest possible date of the inscription (year CE, negative = BCE)."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:integer .

epig:divinityClassificationReasoning a owl:DatatypeProperty ;
    rdfs:label "divinity classification reasoning"@en ;
    rdfs:comment "Explanation for why this person was classified as a divinity."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:divinityType a owl:ObjectProperty ;
    rdfs:label "divinity type"@en ;
    rdfs:comment "The specific deity or deified figure this person represents."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:DivinityType .

epig:ethnicity a owl:DatatypeProperty ;
    rdfs:label "ethnicity"@en ;
    rdfs:comment "Ethnic or cultural origin inferred for the person."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:ethnicityEvidence a owl:DatatypeProperty ;
    rdfs:label "ethnicity evidence"@en ;
    rdfs:comment "Textual evidence used to infer the person's ethnic origin."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:evidence a owl:DatatypeProperty ;
    rdfs:label "evidence"@en ;
    rdfs:comment "The Latin text passage that provides evidence for this assertion."@en ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:genderEvidence a owl:DatatypeProperty ;
    rdfs:label "gender evidence"@en ;
    rdfs:comment "Textual evidence used to determine the person's gender."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:hasBenefaction a owl:ObjectProperty ;
    rdfs:label "has benefaction"@en ;
    rdfs:comment "Links a person to a benefaction they performed."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Benefaction .

epig:hasBrother a owl:ObjectProperty ;
    rdfs:label "has brother"@en ;
    rdfs:comment "Sibling relationship (brother)."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:hasCareerPosition a owl:ObjectProperty ;
    rdfs:label "has career position"@en ;
    rdfs:comment "Links a person to one of their career positions."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:CareerPosition .

epig:hasDaughter a owl:ObjectProperty ;
    rdfs:label "has daughter"@en ;
    rdfs:comment "Direct parent–daughter relationship."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:hasFather a owl:ObjectProperty ;
    rdfs:label "has father"@en ;
    rdfs:comment "Direct father–child relationship."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:hasMother a owl:ObjectProperty ;
    rdfs:label "has mother"@en ;
    rdfs:comment "Direct mother–child relationship."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:hasSister a owl:ObjectProperty ;
    rdfs:label "has sister"@en ;
    rdfs:comment "Sibling relationship (sister)."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:hasSon a owl:ObjectProperty ;
    rdfs:label "has son"@en ;
    rdfs:comment "Direct parent–son relationship."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:isDivinity a owl:DatatypeProperty ;
    rdfs:label "is divinity"@en ;
    rdfs:comment "True if the person is a deity or deified figure rather than a historical human."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:boolean .

epig:mainSubject a owl:ObjectProperty ;
    rdfs:label "main subject"@en ;
    rdfs:comment "The principal person(s) commemorated or named in the inscription."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range foaf:Person .

epig:mentions a owl:ObjectProperty ;
    rdfs:label "mentions"@en ;
    rdfs:comment "Any entity (person, community, relationship) directly referenced in the inscription."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology .

epig:nextPosition a owl:ObjectProperty ;
    rdfs:label "next position"@en ;
    rdfs:comment "The career position held after this one."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:CareerPosition .

epig:nomen a owl:ObjectProperty ;
    rdfs:label "nomen"@en ;
    rdfs:comment "The Roman nomen gentilicium of the person."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Nomen .

epig:normalizedName a owl:DatatypeProperty ;
    rdfs:label "normalized name"@en ;
    rdfs:comment "A standardised form of the person's name for disambiguation."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:notes a owl:DatatypeProperty ;
    rdfs:label "notes"@en ;
    rdfs:comment "Free-text notes or remarks about this entity."@en ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:object a owl:DatatypeProperty ;
    rdfs:label "object"@en ;
    rdfs:comment "The physical object or service provided in the benefaction."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:objectDescription a owl:DatatypeProperty ;
    rdfs:label "object description"@en ;
    rdfs:comment "A description of the benefaction object."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:objectType a owl:DatatypeProperty ;
    rdfs:label "object type"@en ;
    rdfs:comment "The category of the benefaction object (building, statue, etc.)."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:order a owl:DatatypeProperty ;
    rdfs:label "order"@en ;
    rdfs:comment "The sequence number of this position within the person's career."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:integer .

epig:place a owl:ObjectProperty ;
    rdfs:label "place"@en ;
    rdfs:comment "The place where the inscription was found."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Place .

epig:pleiadesId a owl:DatatypeProperty ;
    rdfs:label "Pleiades ID"@en ;
    rdfs:comment "Pleiades gazetteer identifier for the find-spot."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:position a owl:DatatypeProperty ;
    rdfs:label "position"@en ;
    rdfs:comment "The position title as it appears in the inscription."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:positionAbstract a owl:DatatypeProperty ;
    rdfs:label "position abstract"@en ;
    rdfs:comment "A high-level, abstract label for this type of office (e.g. 'consul', 'flamen')."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:positionNormalized a owl:DatatypeProperty ;
    rdfs:label "position normalized"@en ;
    rdfs:comment "A normalised form of the position title."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:positionType a owl:DatatypeProperty ;
    rdfs:label "position type"@en ;
    rdfs:comment "Broad category of the office (military, imperial-administration, priesthood, etc.)."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:praenomen a owl:ObjectProperty ;
    rdfs:label "praenomen"@en ;
    rdfs:comment "The Roman praenomen of the person."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Praenomen .

epig:previousPosition a owl:ObjectProperty ;
    rdfs:label "previous position"@en ;
    rdfs:comment "The career position held before this one."@en ;
    rdfs:domain epig:CareerPosition ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:CareerPosition .

epig:province a owl:ObjectProperty ;
    rdfs:label "province"@en ;
    rdfs:comment "The Roman province in which the inscription was found."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:Province .

epig:recipientName a owl:DatatypeProperty ;
    rdfs:label "recipient name"@en ;
    rdfs:comment "The name of the specific recipient of the benefaction."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:recipientType a owl:DatatypeProperty ;
    rdfs:label "recipient type"@en ;
    rdfs:comment "The type of recipient of the benefaction (community, deity, individual, etc.)."@en ;
    rdfs:domain epig:Benefaction ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:relationshipProperty a owl:DatatypeProperty ;
    rdfs:label "relationship property"@en ;
    rdfs:comment "The specific relationship role (e.g. 'father', 'patron', 'soldier')."@en ;
    rdfs:domain epig:Relationship ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:relationshipType a owl:ObjectProperty ;
    rdfs:label "relationship type"@en ;
    rdfs:comment "The high-level category of the relationship."@en ;
    rdfs:domain epig:Relationship ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:RelationshipType .

epig:socialStatus a owl:ObjectProperty ;
    rdfs:label "social status"@en ;
    rdfs:comment "The social rank or civic role of the person."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range epig:SocialStatus .

epig:source a owl:ObjectProperty ;
    rdfs:label "source"@en ;
    rdfs:comment "The entity from which the relationship originates."@en ;
    rdfs:domain epig:Relationship ;
    rdfs:isDefinedBy epig:ontology .

epig:target a owl:ObjectProperty ;
    rdfs:label "target"@en ;
    rdfs:comment "The entity to which the relationship points."@en ;
    rdfs:domain epig:Relationship ;
    rdfs:isDefinedBy epig:ontology .

epig:text a owl:DatatypeProperty ;
    rdfs:label "inscription text"@en ;
    rdfs:comment "The transcribed Latin text of the inscription."@en ;
    rdfs:domain epig:Inscription ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:string .

epig:wikidataEntity a owl:DatatypeProperty ;
    rdfs:label "Wikidata entity"@en ;
    rdfs:comment "Wikidata QID for this person."@en ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy epig:ontology ;
    rdfs:range xsd:anyURI .

