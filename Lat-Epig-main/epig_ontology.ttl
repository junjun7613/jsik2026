epig:Cognomen a owl:Class ;
    rdfs:label "Cognomen"@en ;
    rdfs:comment "A Roman personal cognomen."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Nomen a owl:Class ;
    rdfs:label "Nomen"@en ;
    rdfs:comment "A Roman gentilicial name (family name)."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Praenomen a owl:Class ;
    rdfs:label "Praenomen"@en ;
    rdfs:comment "A Roman praenomen (first name)."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Community a owl:Class ;
    rdfs:label "Community"@en ;
    rdfs:comment "A social, political, military, or religious group mentioned in an inscription."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Province a owl:Class ;
    rdfs:label "Province"@en ;
    rdfs:comment "A Roman administrative province."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Relationship a owl:Class ;
    rdfs:label "Relationship"@en ;
    rdfs:comment "A directed social relationship between two entities (persons or communities)."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Inscription a owl:Class ;
    rdfs:label "Inscription"@en ;
    rdfs:comment "A Latin epigraphic inscription from the EDCS corpus."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:RelationshipType a owl:Class ;
    rdfs:label "Relationship Type"@en ;
    rdfs:comment "A high-level category of social relationship (family, patronage, etc.)."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:CareerPosition a owl:Class ;
    rdfs:label "Career Position"@en ;
    rdfs:comment "A single office or position held during a person's career."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Benefaction a owl:Class ;
    rdfs:label "Benefaction"@en ;
    rdfs:comment "An act of public generosity (construction, donation, games, etc.) recorded in an inscription."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:Place a owl:Class ;
    rdfs:label "Place"@en ;
    rdfs:comment "A geographical location where an inscription was found."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:CommunityType a owl:Class ;
    rdfs:label "Community Type"@en ;
    rdfs:comment "A category of community or collective body (city, legion, collegium, etc.)."@en ;
    rdfs:isDefinedBy epig:ontology .

foaf:Person a owl:Class ;
    rdfs:label "Person"@en ;
    rdfs:comment "A person mentioned in one or more inscriptions."@en ;
    rdfs:isDefinedBy epig:ontology ;
    owl:equivalentClass foaf:Person .

epig:SocialStatus a owl:Class ;
    rdfs:label "Social Status"@en ;
    rdfs:comment "A controlled-vocabulary term for a person's social rank or civic role."@en ;
    rdfs:isDefinedBy epig:ontology .

epig:ontology a owl:Ontology ;
    rdfs:label "Epigraphic Inscription Ontology"@en ;
    rdfs:comment "OWL ontology for Latin epigraphic inscriptions, derived from the LLM-enriched EDCS career-graph dataset."@en ;
    owl:imports foaf: ;
    owl:versionInfo "1.0" .

epig:DivinityType a owl:Class ;
    rdfs:label "Divinity Type"@en ;
    rdfs:comment "A deity or deified figure referenced in inscriptions."@en ;
    rdfs:isDefinedBy epig:ontology .

